<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".view.sugestao.SugestaoFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/txtSugestoesNutricionais"
            style="@style/txt_longos_center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/txt_sugestoes_nutricionais_gerais" />

        <TextView
            android:id="@+id/txtSugestoesAlimentares"
            style="@style/txt_longos_start"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="40dp"
            android:text="@string/txt_sugestoes_nutricionais_idosos" />

        <TextView
            android:id="@+id/txtDicasNutricionais"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>